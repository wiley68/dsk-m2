<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../Config/etc/system_file.xsd">
    <system>
        <tab id="avalon_dskapipaymentmethod_tab" translate="label" sortOrder="700">
            <label>Банка ДСК покупки на Кредит</label>
        </tab>
        <section id="avalon_dskapipaymentmethod_tab_options" translate="label" sortOrder="500" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Настройка на Калкулатора</label>
            <tab>avalon_dskapipaymentmethod_tab</tab>
            <resource>Avalon_Dskapipayment::configure</resource>
            <group id="properties_dskapi" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Общи настройки</label>
                <field id="dskapi_status" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Банка ДСК покупки на Кредит</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Дава възможност на Вашите клиенти да закупуват стока на изплащане с Банка ДСК.]]></comment>
                </field>
                <field id="dskapi_cid" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Уникален идентификатор на магазина:</label>
                    <comment><![CDATA[Уникален идентификатор на магазина в системата на Банка ДСК.]]></comment>
                </field>
                <field id="dskapi_reklama" translate="label" type="select" sortOrder="3" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Визуализиране на реклама</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Можете да включвате или изключвате показването на реклама в началната страница на магазина.]]></comment>
                </field>
                <field id="dskapi_gap" translate="label" type="text" sortOrder="4" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Свободно място над бутона</label>
                    <comment><![CDATA[Свободно място над бутона в px.]]></comment>
                    <frontend_class>validate-digits</frontend_class>
                </field>
            </group>
        </section>
        <section id="payment">
            <group id="dskapipaymentmethod" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Банка ДСК</label>
                <field id="active" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Разрешен</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Наименование</label>
                </field>
                <field id="order_status" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Състояние на новата поръчка</label>
                    <source_model>Avalon\Dskapipayment\Model\Config\Source\Order\Status\Pendingpayment</source_model>
                </field>
                <field id="allowspecific" translate="label" type="allowspecific" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Избор на държави</label>
                    <source_model>Magento\Payment\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="41" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Важи за следните държави</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                    <can_be_empty>1</can_be_empty>
                </field>
                <field id="instructions" translate="label" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Инструкции</label>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Сортиране</label>
                    <frontend_class>validate-number</frontend_class>
                </field>
            </group>
            <!-- payment-group -->
        </section>
    </system>
</config>
